<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nosto ROI Calculator</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <!-- Chart.js for simplicity in a single HTML file -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body { background-color: black; color: #cbd5e1; font-family: sans-serif; }
        .nosto-pink { color: #ec4899; }
        .bg-nosto-pink { background-color: #ec4899; }
        input[type="range"] { accent-color: #ec4899; }
        .card { background-color: #0f172a; border: 1px solid #1e293b; border-radius: 1rem; }
    </style>
</head>
<body class="p-4">
    <div class="max-w-4xl mx-auto">
        <!-- Header -->
        <div class="flex items-center justify-between mb-8 gap-4">
            <div class="flex items-center gap-3">
                <div class="bg-nosto-pink p-2 rounded-lg text-white">
                    <i data-lucide="zap"></i>
                </div>
                <h1 class="text-xl font-black text-white uppercase tracking-tighter">Nosto ROI Projection</h1>
            </div>
            <div class="text-right">
                <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">Est. Annual ROI</p>
                <p id="roi-display" class="text-3xl font-black nosto-pink">19.69x</p>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
            <!-- Inputs -->
            <div class="card p-6 space-y-4">
                <h2 class="text-xs font-black uppercase tracking-widest text-slate-500 mb-2 flex items-center gap-2">
                    <i data-lucide="settings" size="14"></i> Parameters
                </h2>
                <div>
                    <label class="block text-[10px] font-bold uppercase mb-1">Monthly Traffic</label>
                    <input type="number" id="traffic" value="316667" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-white outline-none focus:border-pink-500">
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-[10px] font-bold uppercase mb-1">CVR %</label>
                        <input type="number" id="cvr" step="0.01" value="2.17" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-white outline-none focus:border-pink-500">
                    </div>
                    <div>
                        <label class="block text-[10px] font-bold uppercase mb-1">AOV $</label>
                        <input type="number" id="aov" value="101" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-white outline-none focus:border-pink-500">
                    </div>
                </div>
                <div class="pt-2">
                    <label class="block text-[10px] font-bold uppercase mb-1 flex justify-between">
                        <span>Target Uplift</span>
                        <span id="uplift-val" class="nosto-pink">10%</span>
                    </label>
                    <input type="range" id="targetUplift" min="1" max="25" value="10" class="w-full">
                </div>
                <div class="pt-2 bg-pink-600/10 p-3 rounded-lg border border-pink-600/20">
                    <label class="block text-[10px] font-bold uppercase mb-1 text-pink-500">Annual Software Cost</label>
                    <input type="number" id="cost" value="25765" class="w-full bg-transparent border-b border-pink-500/30 py-1 text-white font-bold outline-none">
                </div>
            </div>

            <!-- Visualization -->
            <div class="card p-6 flex flex-col justify-center">
                <canvas id="growthChart" height="200"></canvas>
                <div class="mt-6 space-y-3 text-sm">
                    <div class="flex justify-between border-b border-slate-800 pb-2">
                        <span class="text-slate-500">Total Annual Uplift</span>
                        <span id="uplift-rev" class="text-white font-bold">$0</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-slate-500">Monthly Payback (M1)</span>
                        <span id="payback" class="text-pink-500 font-bold">$0</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        lucide.createIcons();
        const ctx = document.getElementById('growthChart').getContext('2d');
        let chart;

        function calculate() {
            const traffic = parseFloat(document.getElementById('traffic').value);
            const cvr = parseFloat(document.getElementById('cvr').value) / 100;
            const aov = parseFloat(document.getElementById('aov').value);
            const cost = parseFloat(document.getElementById('cost').value);
            const targetUplift = parseFloat(document.getElementById('targetUplift').value);
            
            document.getElementById('uplift-val').innerText = targetUplift + '%';

            const baseMonthly = traffic * cvr * aov;
            const months = Array.from({length: 12}, (_, i) => i + 1);
            const dataBaseline = months.map(() => baseMonthly);
            const dataNosto = months.map(m => {
                const ramp = 2.5 + ((targetUplift - 2.5) * (m - 1) / 11);
                return baseMonthly * (1 + (ramp / 100));
            });

            const annualUplift = dataNosto.reduce((a, b) => a + b, 0) - (baseMonthly * 12);
            const roi = (annualUplift / cost).toFixed(2);
            
            document.getElementById('roi-display').innerText = roi + 'x';
            document.getElementById('uplift-rev').innerText = new Intl.NumberFormat('en-AU', { style: 'currency', currency: 'AUD' }).format(annualUplift);
            document.getElementById('payback').innerText = new Intl.NumberFormat('en-AU', { style: 'currency', currency: 'AUD' }).format(dataNosto[0] - baseMonthly);

            updateChart(months, dataBaseline, dataNosto);
        }

        function updateChart(labels, baseline, nosto) {
            if (chart) chart.destroy();
            chart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels.map(m => 'M' + m),
                    datasets: [
                        {
                            label: 'Nosto',
                            data: nosto,
                            borderColor: '#ec4899',
                            backgroundColor: 'rgba(236, 72, 153, 0.1)',
                            fill: true,
                            tension: 0.4,
                            pointRadius: 0
                        },
                        {
                            label: 'Baseline',
                            data: baseline,
                            borderColor: '#334155',
                            borderDash: [5, 5],
                            fill: false,
                            tension: 0,
                            pointRadius: 0
                        }
                    ]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { display: false },
                        x: { grid: { display: false }, ticks: { color: '#475569' } }
                    }
                }
            });
        }

        ['traffic', 'cvr', 'aov', 'cost', 'targetUplift'].forEach(id => {
            document.getElementById(id).addEventListener('input', calculate);
        });

        calculate();
    </script>
</body>
</html>
